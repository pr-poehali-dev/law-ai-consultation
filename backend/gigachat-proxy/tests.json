{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "send-otp bad email",
      "method": "POST",
      "path": "/",
      "body": {"action": "send-otp", "email": ""},
      "expectedStatus": 400,
      "expectedBody": {"error": "Некорректный email"},
      "bodyMatcher": "partial"
    },
    {
      "name": "verify-otp wrong code",
      "method": "POST",
      "path": "/",
      "body": {"action": "verify-otp", "email": "test@example.com", "code": "000000"},
      "expectedStatus": 401,
      "expectedBody": {"error": "Неверный или истёкший код"},
      "bodyMatcher": "partial"
    },
    {
      "name": "me unauthorized",
      "method": "POST",
      "path": "/",
      "body": {"action": "me"},
      "expectedStatus": 401,
      "expectedBody": {"error": "Не авторизован"},
      "bodyMatcher": "partial"
    },
    {
      "name": "YandexGPT - chat",
      "method": "POST",
      "path": "/",
      "body": {
        "mode": "chat",
        "engine": "yandex",
        "messages": [{"role": "user", "content": "Что такое исковая давность в РФ?"}]
      },
      "expectedStatus": 200,
      "expectedBody": {"answer": "string"},
      "bodyMatcher": "partial"
    }
  ]
}