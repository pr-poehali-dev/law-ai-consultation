{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "register — missing name",
      "method": "POST",
      "path": "/",
      "body": {"action": "register", "name": "", "email": "test@example.com", "phone": "+79991234567", "password": "secret123", "agreed_to_terms": true},
      "expectedStatus": 400,
      "expectedBody": {"error": "Введите имя"},
      "bodyMatcher": "partial"
    },
    {
      "name": "register — short password",
      "method": "POST",
      "path": "/",
      "body": {"action": "register", "name": "Иван", "email": "test@example.com", "phone": "+79991234567", "password": "123", "agreed_to_terms": true},
      "expectedStatus": 400,
      "expectedBody": {"error": "Пароль должен быть не менее 6 символов"},
      "bodyMatcher": "partial"
    },
    {
      "name": "register — no agreement",
      "method": "POST",
      "path": "/",
      "body": {"action": "register", "name": "Иван", "email": "test@example.com", "phone": "+79991234567", "password": "secret123", "agreed_to_terms": false},
      "expectedStatus": 400,
      "expectedBody": {"error": "Необходимо согласие на обработку персональных данных"},
      "bodyMatcher": "partial"
    },
    {
      "name": "login — wrong password",
      "method": "POST",
      "path": "/",
      "body": {"action": "login", "email": "nobody@example.com", "password": "wrongpass"},
      "expectedStatus": 401,
      "expectedBody": {"error": "Неверный email или пароль"},
      "bodyMatcher": "partial"
    },
    {
      "name": "me — unauthorized",
      "method": "POST",
      "path": "/",
      "body": {"action": "me"},
      "expectedStatus": 401,
      "expectedBody": {"error": "Не авторизован"},
      "bodyMatcher": "partial"
    },
    {
      "name": "YandexGPT - chat",
      "method": "POST",
      "path": "/",
      "body": {
        "mode": "chat",
        "engine": "yandex",
        "messages": [{"role": "user", "content": "Что такое исковая давность в РФ?"}]
      },
      "expectedStatus": 200,
      "expectedBody": {"answer": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "file_analyze — missing file",
      "method": "POST",
      "path": "/",
      "body": {"mode": "file_analyze", "filename": "test.pdf"},
      "expectedStatus": 400,
      "expectedBody": {"error": "file required"},
      "bodyMatcher": "partial"
    },
    {
      "name": "file_analyze — unsupported format",
      "method": "POST",
      "path": "/",
      "body": {"mode": "file_analyze", "file": "dGVzdA==", "filename": "test.txt"},
      "expectedStatus": 400,
      "bodyMatcher": "partial"
    },
    {
      "name": "report — unauthorized",
      "method": "POST",
      "path": "/",
      "body": {"action": "report", "message": "тест"},
      "expectedStatus": 401,
      "expectedBody": {"error": "Не авторизован"},
      "bodyMatcher": "partial"
    }
  ]
}